# Path to the SQLite database file.
# Relative paths resolve from the project root.
DATABASE_PATH=./scp-console.db

# Base URL of the SCP server to use for testing.
# For the bundled reference merchant (Acme Outdoor Co.), this is the local Hono server.
# Override to point at your own production SCP endpoint.
SCP_TEST_ENDPOINT=http://localhost:8787/v1
